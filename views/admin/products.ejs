<%- include("../../views/partials/admin/header") %>
    <style>
        .action-btn {
            width: 90px;
            margin: 2px;
        }
    </style>

    <div class="content-header">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="content-title card-title">Products</h2>
            <a href="/admin/products/add" class="btn btn-dark">Add Book</a>
        </div>
    </div>

    <header class="card-header text-center mb-4">
        <form action="" method="get" class="d-flex justify-content-center">
            <div class="input-group input-group-sm border border-1 border-grey rounded-pill" style="width: 500px;">
                <input type="text" class="form-control border-0 rounded-pill" placeholder="Search products or brands"
                    name="search" value="<%= locals.search || '' %>">
                <button class="btn border-0" type="submit">Search</button>
            </div>
        </form>
    </header>

    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th scope="col"><b>Book name</b></th>
                    <th scope="col"><b>Author</b></th>
                    <th scope="col"><b>Category</b></th>
                    <th scope="col"><b>Sale Price</b></th>
                    <th scope="col"><b>Offer</b></th>
                    <th scope="col"><b>Quantity</b></th>
                    <th scope="col"><b>Offer Action</b></th>
                    <th scope="col"><b>Status</b></th>
                    <th scope="col"><b>Edit</b></th>
                    <th scope="col"><b>Delete</b></th>
                </tr>
            </thead>
            <tbody id="productTableBody">

                <%for(let i=0;i<data.length;i++){%>

                    <tr id="row-<%=data[i]._id%>">
                        <td>
                            <%=data[i].productName%>
                        </td>
                        <td>
                            <%=data[i].author%>
                        </td>
                        <td>
                            <%=data[i].category?.name || 'N/A' %>
                        </td>
                        <td>
                            <%=data[i].salePrice%>
                        </td>
                        <td>
                            <%if(data[i].productOffer){%>
                                <%=data[i].productOffer%>%
                                    <%}else{%>
                                        0%
                                        <%}%>
                        </td>
                        <td>
                            <%=data[i].stock !==undefined ? data[i].stock : 'N/A' %>
                        </td>

                        <td>
                            <%if(!data[i].productOffer){%>
                                <button type="button" class="btn btn-info action-btn"
                                    onclick="addOffer('<%=data[i]._id%>')">
                                    Add Offer
                                </button>
                                <%}else{%>
                                    <button type="button" class="btn btn-warning action-btn"
                                        onclick="removeOffer('<%=data[i]._id%>')">
                                        Remove Offer
                                    </button>
                                    <%}%>
                        </td>

                        <td>
                            <%if(data[i].status !=='Discontinued' ){%>
                                <button type="button" class="btn btn-danger action-btn"
                                    onclick="toggleBlock('<%=data[i]._id%>', true)">
                                    Block
                                </button>
                                <%}else{%>
                                    <button type="button" class="btn btn-success action-btn"
                                        onclick="toggleBlock('<%=data[i]._id%>', false)">
                                        Unblock
                                    </button>
                                    <%}%>
                        </td>

                        <td>
                            <a href="/admin/products/edit/<%=data[i]._id%>" class="btn btn-info action-btn text-white"
                                style="text-decoration:none;">
                                Edit
                            </a>
                        </td>

                        <td>
                            <button type="button" class="btn btn-danger action-btn"
                                onclick="softDeleteProduct('<%=data[i]._id%>')">
                                Delete
                            </button>
                        </td>
                    </tr>
                    <%}%>
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <% for (let i=1; i <=totalPages; i++) { %>
                    <li class="page-item <%=(i === parseInt(currentPage)) ? 'active' :'' %>">
                        <a class="page-link" href="?page=<%= i %>">
                            <%= i %>
                        </a>
                    </li>
                    <% } %>
            </ul>
        </nav>
    </div>

    <script>
        // ---------------- Soft delete ----------------
        function softDeleteProduct(productId) {
            Swal.fire({
                title: 'Delete this product?',
                text: "It will be hidden from customers. You can restore it later.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (!result.isConfirmed) return;

                $.ajax({
                    url: '/admin/products/delete/' + productId,
                    method: 'PATCH',
                    success: function (res) {
                        if (res.success) {
                            document.getElementById('row-' + productId).remove();
                            Swal.fire('Deleted', 'Product has been deleted.', 'success');
                        } else {
                            Swal.fire('Error', res.message || 'Something went wrong.', 'error');
                        }
                    },
                    error: function () {
                        Swal.fire('Error', 'Could not delete the product.', 'error');
                    }
                });
            });
        }

        // ---------------- Block / Unblock ----------------
        function toggleBlock(productId, block) {
            const label = block ? 'block' : 'unblock';
            Swal.fire({
                title: `Are you sure you want to ${label} this product?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: `Yes, ${label} it`,
            }).then((result) => {
                if (!result.isConfirmed) return;

                $.ajax({
                    url: '/admin/products/toggle-block/' + productId,
                    method: 'PATCH',
                    data: { block: block },
                    success: function (res) {
                        if (res.success) {
                            location.reload();
                        } else {
                            Swal.fire('Error', res.message || 'Something went wrong.', 'error');
                        }
                    },
                    error: function () {
                        Swal.fire('Error', 'Could not update product status.', 'error');
                    }
                });
            });
        }

        // ---------------- Offer ----------------
        async function addOffer(productId) {
            try {
                const { value: percentage } = await Swal.fire({
                title: 'Offer in percentage',
                input: 'number',
                inputLabel: 'Percentage',
                inputPlaceholder: '%',
                inputAttributes: { min: 1, max: 90 },
                showCancelButton: true,
                confirmButtonText: 'Apply'
            });

            // User cancelled, or submitted the dialog with an empty value
            if (!percentage) return;

            $.ajax({
                url: '/admin/addProductOffer',
                method: 'POST',
                data: {
                    percentage: percentage,
                    productId: productId
                },
                success: (res) => {
                    if (res.status === true) {
                        Swal.fire('Offer added', 'The offer has been applied.', 'success')
                            .then(() => location.reload());
                    } else {
                        Swal.fire('Error', res.data.message || 'Something went wrong.', 'error');
                        console.log(res)
                        
                    }
                },
            })
            } catch (error) {
                Swal.fire('Error', 'Could not add offer.', 'error');
                    console.log(error);
            }}

        function removeOffer(productId) {
            try {
                Swal.fire({
                    title: 'Remove this offer?',
                    text: 'Are you sure you want to remove this offer?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33', // FIX: was missing the leading '#', invalid CSS color
                    confirmButtonText: 'Yes, remove it',
                    timer: 5000,
                    timerProgressBar: true
                }).then((result) => {
                    if (!result.isConfirmed) return;

                    $.ajax({
                        url: '/admin/removeProductOffer/',
                        method: 'POST',
                        data: {
                            productId: productId
                        },
                        success: (res) => {
                            if (res.status === true) {
                                // FIX: same reload-before-alert ordering issue as addOffer
                                Swal.fire('Removed!', 'The offer has been removed.', 'success')
                                    .then(() => location.reload());
                            } else {
                                Swal.fire('Error', res.message || 'Something went wrong.', 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Error', 'Could not remove offer.', 'error');
                        }
                    });
                });
            } catch (error) {
                console.error(error);
            }
        }
    </script>

    <%- include("../../views/partials/admin/footer") %>
